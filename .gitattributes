# Normalize line endings to LF in the repo, checkout as LF on all platforms
* text=auto eol=lf

# Shell scripts — always LF
*.sh text eol=lf
*.bash text eol=lf

# YAML — always LF
*.yml text eol=lf
*.yaml text eol=lf

# TypeScript / JavaScript
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# SQL / migrations
*.sql text eol=lf

# Config / env files
*.env text eol=lf
*.conf text eol=lf

# Binaries — no line-ending conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.otf binary
*.zip binary
*.tar binary
*.gz binary
*.tflite binary
*.pb binary
