# ═══════════════════════════════════════════════════════════════════════════════
# PROMPT Genie Backend — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and update values for your environment
# NEVER commit .env to version control
#
# Generate secrets with:
#   JWT_SECRET=$(openssl rand -base64 64)
#   JWT_REFRESH_SECRET=$(openssl rand -base64 64)
#   PIN_ENCRYPTION_KEY=$(openssl rand -base64 32)
# ═══════════════════════════════════════════════════════════════════════════════

# ─ APPLICATION ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
API_VERSION=v1
APP_NAME=PROMPT Genie
APP_VERSION=1.0.0
TZ=UTC
# Domain names used by nginx (set to your VPS domain in production)
API_DOMAIN=api.genieinprompt.app
FRONTEND_DOMAIN=genieinprompt.app
# Email for Let's Encrypt certificate issuance and expiry notices (deploy.sh uses this)
CERTBOT_EMAIL=admin@genieinprompt.app

# ─ DATABASE (PostgreSQL 15) ────────────────────────────────────────────────────
DB_TYPE=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=promptgenie_dev
DB_SYNCHRONIZE=false
DB_LOGGING=true
DB_SSL=false
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_MIGRATIONS_RUN=true
DB_MIGRATIONS_DIR=src/database/migrations

# ─ REDIS CACHE (Redis 7) ────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_TTL=3600
REDIS_SESSION_TTL=86400

# ─ JWT AUTHENTICATION (7 days access, 30 days refresh) ──────────────────────────
JWT_SECRET=your-super-secure-jwt-secret-min-64-chars-very-random-string-change-in-prod
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-min-64-chars-very-random-string-change-prod
JWT_REFRESH_EXPIRES_IN=30d

# ─ ENCRYPTION & SECURITY ───────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
PIN_ENCRYPTION_KEY=your-32-char-encryption-key-for-pins
PIN_ENCRYPTION_IV=your-16-char-iv-for-pins
PIN_ALGORITHM=aes-256-cbc

# ─ CORS & SECURITY ──────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5000,http://localhost:3000,http://localhost:8080
CORS_CREDENTIALS=true
CORS_METHODS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_ALLOW_HEADERS=Content-Type,Authorization
FORCE_HTTPS=false
TRUST_PROXY=true

# ─ EMAIL (SendGrid) ─────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.your-sendgrid-api-key-here
EMAIL_FROM=noreply@genieinprompt.app
EMAIL_FROM_NAME=PROMPT Genie
EMAIL_SUPPORT=support@genieinprompt.app
EMAIL_REPLY_TO=reply@genieinprompt.app

# ─ SMS/OTP (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACyour-account-sid-here
TWILIO_AUTH_TOKEN=your-auth-token-here
TWILIO_PHONE_NUMBER=+1234567890
SMS_ENABLED=true
SMS_RATE_LIMIT=3
SMS_RATE_LIMIT_WINDOW=3600

# ─ FILE UPLOAD & STORAGE ────────────────────────────────────────────────────────
MAX_FILE_SIZE=10485760
MAX_UPLOAD_SIZE_MB=100
UPLOAD_DESTINATION=./uploads
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx
ALLOWED_IMAGE_TYPES=jpg,jpeg,png,gif,webp
STORAGE_PROVIDER=local

# ─ AWS S3 (For production file storage) ─────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_S3_URL=
AWS_CLOUDFRONT_URL=

# ─ GOOGLE MAPS (For location & ride-hailing) ────────────────────────────────────
GOOGLE_MAPS_API_KEY=
GOOGLE_MAPS_ENABLED=false
MAX_RIDE_SEARCH_RADIUS_KM=50

# ─ AI/ML FEATURES ──────────────────────────────────────────────────────────────
# Core AI toggle
AI_ENABLED=true
AI_MODEL_PATH=./ml-models
TENSORFLOW_ENABLED=true

# OpenAI-compatible inference API
# Set AI_API_KEY + AI_BASE_URL to point at OpenAI, Azure OpenAI, Ollama, or any
# compatible inference endpoint.  Leave blank to use local/TF-only fallback.
AI_API_KEY=sk-your-openai-or-compatible-api-key-here
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.7
# Max milliseconds to wait for an inference response before timing out
AI_REQUEST_TIMEOUT=30000

# NLP settings (natural.js / compromise)
AI_NLP_LANGUAGE=English
# TF-IDF search index max size (documents kept in memory)
AI_TFIDF_MAX_DOCUMENTS=10000

# Dynamic Pricing
# Hard cap on surge multiplier (1.0 = no surge, 3.5 = max surge default)
AI_SURGE_MAX_MULTIPLIER=3.5
AI_SURGE_PEAK_HOURS=7-9,17-20
# Platform fee percentage (0–100)
AI_PLATFORM_FEE_PCT=8

# Fraud Detection
# Score threshold above which a transaction is hard-blocked
AI_FRAUD_BLOCK_THRESHOLD=0.85
# Score threshold that triggers a manual review flag
AI_FRAUD_REVIEW_THRESHOLD=0.55
# Maximum distance (km) before a location is flagged as anomalous
AI_FRAUD_LOCATION_THRESHOLD_KM=500

# Financial Insights
# Revenue forecast horizon in days
AI_FORECAST_HORIZON_DAYS=30
# Minimum savings rate % to avoid a low-savings alert
AI_SAVINGS_RATE_ALERT_PCT=20

# Collaborative Filtering
AI_COLLAB_FILTER_TOP_N=5

# ─ RATE LIMITING ────────────────────────────────────────────────────────────────
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
AUTH_RATE_LIMIT=5
AUTH_RATE_LIMIT_WINDOW=900000
API_RATE_LIMIT=1000
API_RATE_LIMIT_WINDOW=3600000

# ─ QUEUE & JOBS (Bull + Redis) ──────────────────────────────────────────────────
QUEUE_ENABLED=true
QUEUE_DEFAULT_ATTEMPTS=3
QUEUE_DEFAULT_BACKOFF=5000
QUEUE_CLEAN_COMPLETED=true
QUEUE_CLEAN_FAILED=false

# ─ LOGGING (Winston) ────────────────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FILE_PATH=./logs
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=30
LOG_FORMAT=json
LOG_CONSOLE=true

# ─ MONITORING & HEALTH CHECKS ──────────────────────────────────────────────────
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=30000
METRICS_ENABLED=false
PROFILING_ENABLED=false

# ─ SWAGGER/API DOCUMENTATION ───────────────────────────────────────────────────
ENABLE_SWAGGER=true
SWAGGER_PATH=/api/docs
SWAGGER_TITLE=PROMPT Genie API
SWAGGER_DESCRIPTION=Complete API documentation
SWAGGER_VERSION=1.0.0

# ─ DATABASE BACKUP & MAINTENANCE ───────────────────────────────────────────────
BACKUP_ENABLED=false
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
MAINTENANCE_ENABLED=false

# ─ FEATURE FLAGS ────────────────────────────────────────────────────────────────
FEATURE_BIOMETRIC_AUTH=true
FEATURE_PIN_PROTECTION=true
FEATURE_OFFLINE_MODE=true
FEATURE_PUSH_NOTIFICATIONS=false
FEATURE_REAL_TIME_CHAT=true
FEATURE_RIDE_HAILING=true
FEATURE_FINANCIAL_OPERATIONS=true
LOG_TO_CONSOLE=true
LOG_TO_FILE=false

# ─ PAYMENT FACILITATOR (Q Points Market Cash Settlement) ───────────────────────
# Secret and public keys for the licensed cash payment facilitator.
# Use mock_* keys in development/staging to activate mock mode automatically.
PAYMENT_FACILITATOR_SECRET_KEY=mock_secret_key_replace_in_prod
PAYMENT_FACILITATOR_PUBLIC_KEY=mock_public_key_replace_in_prod
PAYMENT_FACILITATOR_WEBHOOK_SECRET=replace_with_strong_webhook_secret_32_chars

# ─ Q POINTS MARKET – AI LIQUIDITY MANAGER ──────────────────────────────────────
# Master toggle – set to true in production to enable the AI market maker.
AI_MARKET_ENABLED=false

# UUID of the AI participant's user record (must exist in the users table).
# The migration seeds this UUID with an initial balance of 50,000 QP.
# Create the matching users row before running migrations in production.
AI_PARTICIPANT_USER_ID=00000000-0000-0000-0000-000000000001

# Inventory targets (Q Points) — proportional to the 500 trillion hard cap
# Target: 50% | Min: 10% | Max: 98% of total supply
AI_TARGET_INVENTORY=250000000000000
AI_MIN_INVENTORY=50000000000000
AI_MAX_INVENTORY=490000000000000
QPOINTS_TOTAL_SUPPLY=500000000000000

# Market-making spread target (percent, e.g. 2.0 = 2%)
AI_TARGET_SPREAD_PCT=2.0

# Order sizing
AI_ORDER_BASE_QTY=500
AI_MAX_ORDER_QTY=2500

# Safety caps
AI_MAX_OPEN_ORDERS=10
AI_ORDER_TTL_SECONDS=300
AI_RUN_INTERVAL_SECONDS=30
AI_MIN_CASH_RESERVE_USD=5000

# ─ WEBSOCKET (Socket.IO) ────────────────────────────────────────────────────────
WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=3001
WEBSOCKET_CORS_ORIGIN=http://localhost:3000

# ─ BACKGROUND JOBS (Bull) ──────────────────────────────────────────────────────
# QUEUE_ENABLED defined above (QUEUE & JOBS section)
QUEUE_CONCURRENCY=5
PROCESS_EMAILS=true
PROCESS_SMS=true

# ─ HEALTH CHECK & MONITORING ────────────────────────────────────────────────────
# HEALTH_CHECK_TIMEOUT and METRICS_ENABLED defined above (MONITORING section)
DB_HEALTH_CHECK_TIMEOUT=5000
REDIS_HEALTH_CHECK_TIMEOUT=5000

# ─ AI & ML SERVICES ─────────────────────────────────────────────────────────────
# AI_ENABLED, AI_API_KEY, AI_BASE_URL defined above (AI/ML FEATURES section)
ML_MODEL_PATH=./ml-models
FEATURE_STORE_UPDATE_INTERVAL=300000

# ─ EXTERNAL SERVICES ───────────────────────────────────────────────────────────
# GOOGLE_MAPS_API_KEY defined above (GOOGLE MAPS section)
STRIPE_PUBLIC_KEY=pk_test_your_key
STRIPE_SECRET_KEY=sk_test_your_key

# ─ FEATURE FLAGS ────────────────────────────────────────────────────────────────
FEATURE_TWO_FACTOR_AUTH=true
FEATURE_SOCIAL_LOGIN=false
FEATURE_MARKETPLACE=true
FEATURE_PAYMENTS=true

# ═══════════════════════════════════════════════════════════════════════════════
# HELPFUL LINKS & COMMANDS
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. Generate secure secrets:
#    Linux/Mac: openssl rand -hex 32
#    Node.js: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# 2. For production, see: .env.COMPLETE file for all available options
#
# 3. To validate this file:
#    npm run validate:env
#
# 4. For Docker setup:
#    docker-compose up -d
#
# ═══════════════════════════════════════════════════════════════════════════════
