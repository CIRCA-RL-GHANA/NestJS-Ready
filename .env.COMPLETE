# ═══════════════════════════════════════════════════════════════════════════════
# OrionStack Production Environment Configuration v1.0.0
# ═══════════════════════════════════════════════════════════════════════════════
# 
# This is the COMPLETE production-ready configuration file.
# All values must be updated before deployment to production.
#
# Generated: March 18, 2026
# Status: Production Ready
# ═══════════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────────
# 1. APPLICATION CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
API_PREFIX=api
API_VERSION=v1

# Application Name
APP_NAME=OrionStack
APP_DESCRIPTION=Complete Full-Stack Application
APP_VERSION=1.0.0

# ───────────────────────────────────────────────────────────────────────────────
# 2. DATABASE CONFIGURATION (PostgreSQL)
# ───────────────────────────────────────────────────────────────────────────────
# Production: Use managed database service (Neon, AWS RDS, Azure Database)
# Local Dev: Use Docker PostgreSQL

DB_TYPE=postgres
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=orionstack_user
DB_PASSWORD=change_me_to_strong_password_min_32_chars_1A2b3C4d5E6f7G8h
DB_NAME=orionstack_prod
DB_SYNCHRONIZE=false
DB_LOGGING=false
DB_SSL=true
DB_SSL_REJECT_UNAUTHORIZED=false

# Connection Pool Settings
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=30000
DB_IDLE_TIMEOUT=30000

# ───────────────────────────────────────────────────────────────────────────────
# 3. REDIS CACHE CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────
# Production: Use managed Redis (AWS ElastiCache, Redis Labs, Upstash)
# Local Dev: Use Docker Redis

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_me_to_strong_redis_password_1A2b3C4d5E6f7G8h
REDIS_DB=0
REDIS_TTL=86400

# Connection Settings
REDIS_POOL_SIZE=10
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=100

# ───────────────────────────────────────────────────────────────────────────────
# 4. AUTHENTICATION & SECURITY
# ───────────────────────────────────────────────────────────────────────────────

# JWT Configuration
JWT_SECRET=change_me_to_random_secret_min_32_chars_generate_with_openssl_rand_32_bytes_hex
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change_me_to_random_secret_min_32_chars_generate_with_openssl_rand_32_bytes_hex_2
JWT_REFRESH_EXPIRES_IN=30d

# Session Configuration
SESSION_SECRET=change_me_to_random_session_secret_1A2b3C4d5E6f7G8h
SESSION_TIMEOUT=3600000

# Password & Security
BCRYPT_ROUNDS=12
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
PIN_ENCRYPTION_KEY=change_me_to_pin_encryption_key_32_chars_hex

# CORS Configuration (comma-separated)
CORS_ORIGIN=https://genieinprompt.app,https://www.genieinprompt.app
CORS_CREDENTIALS=true

# ───────────────────────────────────────────────────────────────────────────────
# 5. EMAIL SERVICE - SendGrid
# ───────────────────────────────────────────────────────────────────────────────

SENDGRID_API_KEY=SG.your_sendgrid_api_key_here
EMAIL_FROM=noreply@genieinprompt.app
EMAIL_FROM_NAME=PROMPT Genie
EMAIL_SUPPORT=support@genieinprompt.app
EMAIL_VERIFICATION_ENABLED=true

# Email Templates
EMAIL_WELCOME_TEMPLATE_ID=your_template_id
EMAIL_FORGOT_PASSWORD_TEMPLATE_ID=your_template_id
EMAIL_ORDER_CONFIRMATION_TEMPLATE_ID=your_template_id

# ───────────────────────────────────────────────────────────────────────────────
# 6. SMS SERVICE - Twilio
# ───────────────────────────────────────────────────────────────────────────────

TWILIO_ACCOUNT_SID=ACyour_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890
SMS_ENABLED=true
SMS_PROVIDER=twilio

# ───────────────────────────────────────────────────────────────────────────────
# 7. FILE UPLOAD & STORAGE
# ───────────────────────────────────────────────────────────────────────────────

# Local Storage (for development/small deployments)
UPLOAD_DESTINATION=./uploads
MAX_FILE_SIZE=10485760

# AWS S3 Configuration (for production)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_S3_BUCKET=promptgenie-uploads-prod
AWS_S3_URL=https://promptgenie-uploads-prod.s3.amazonaws.com
STORAGE_PROVIDER=local

# Allowed file types
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx,ppt,pptx,zip
MAX_UPLOAD_SIZE_MB=100

# ───────────────────────────────────────────────────────────────────────────────
# 8. RATE LIMITING
# ───────────────────────────────────────────────────────────────────────────────

THROTTLE_ENABLED=true
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# Per-endpoint rate limits
AUTH_RATE_LIMIT=5
API_RATE_LIMIT=100
FILE_UPLOAD_RATE_LIMIT=10

# ───────────────────────────────────────────────────────────────────────────────
# 9. LOGGING & MONITORING
# ───────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=info
LOG_FILE_PATH=./logs
LOG_FILE_MAX_SIZE=10485760
LOG_FILE_MAX_FILES=10
LOG_FORMAT=json
LOG_TO_CONSOLE=true
LOG_TO_FILE=true

# Error Tracking (Sentry)
SENTRY_DSN=https://your_sentry_dsn@sentry.io/your_project_id
SENTRY_ENABLED=true

# ───────────────────────────────────────────────────────────────────────────────
# 10. HEALTH CHECK & MONITORING
# ───────────────────────────────────────────────────────────────────────────────

HEALTH_CHECK_TIMEOUT=30000
HEALTH_CHECK_INTERVAL=30000
METRICS_ENABLED=true
METRICS_PORT=9090

# Database health check
DB_HEALTH_CHECK_TIMEOUT=5000
DB_HEALTH_CHECK_INTERVAL=30000

# Redis health check
REDIS_HEALTH_CHECK_TIMEOUT=5000
REDIS_HEALTH_CHECK_INTERVAL=30000

# ───────────────────────────────────────────────────────────────────────────────
# 11. WEBSOCKET CONFIGURATION - Socket.IO
# ───────────────────────────────────────────────────────────────────────────────

WEBSOCKET_ENABLED=true
WEBSOCKET_PORT=3001
WEBSOCKET_NAMESPACE=/socket.io
WEBSOCKET_CORS_ORIGIN=https://genieinprompt.app
WEBSOCKET_HEARTBEAT_TIMEOUT=60000
WEBSOCKET_HEARTBEAT_INTERVAL=25000

# Socket.IO Adapter (for scaled deployments)
SOCKETIO_ADAPTER=redis
SOCKETIO_REDIS_HOST=redis
SOCKETIO_REDIS_PORT=6379

# ───────────────────────────────────────────────────────────────────────────────
# 12. BACKGROUND JOBS - Bull Queue
# ───────────────────────────────────────────────────────────────────────────────

QUEUE_ENABLED=true
QUEUE_REDIS_HOST=redis
QUEUE_REDIS_PORT=6379
QUEUE_CONCURRENCY=5
QUEUE_RETRY_ATTEMPTS=3
QUEUE_RETRY_DELAY=5000

# Job Processors
PROCESS_EMAILS=true
PROCESS_SMS=true
PROCESS_REPORTS=true
PROCESS_CLEANUP=true
PROCESS_SYNC=true

# ───────────────────────────────────────────────────────────────────────────────
# 13. AI & ML SERVICES
# ───────────────────────────────────────────────────────────────────────────────

AI_ENABLED=false
AI_PROVIDER=openai
AI_API_KEY=your_ai_api_key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4
AI_MAX_TOKENS=2000

# ML Models
ML_ENABLED=false
ML_MODEL_PATH=./ml-models
FEATURE_STORE_UPDATE_INTERVAL=300000

# ───────────────────────────────────────────────────────────────────────────────
# 14. EXTERNAL SERVICES
# ───────────────────────────────────────────────────────────────────────────────

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
GOOGLE_MAPS_ENABLED=true

# Payment Processing (Stripe)
STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Analytics
ANALYTICS_ENABLED=true
ANALYTICS_PROVIDER=mixpanel
MIXPANEL_TOKEN=your_mixpanel_token

# ───────────────────────────────────────────────────────────────────────────────
# 15. SECURITY HEADERS & POLICIES
# ───────────────────────────────────────────────────────────────────────────────

# HTTPS & SSL
HTTPS_ENABLED=true
FORCE_HTTPS=true
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true

# Content Security Policy
CSP_ENABLED=true
CSP_DEFAULT_SRC=self
CSP_SCRIPT_SRC=self
CSP_STYLE_SRC=self
CSP_IMG_SRC=self

# X-Frame-Options
X_FRAME_OPTIONS=DENY

# X-Content-Type-Options
X_CONTENT_TYPE_OPTIONS=nosniff

# ───────────────────────────────────────────────────────────────────────────────
# 16. FEATURE FLAGS
# ───────────────────────────────────────────────────────────────────────────────

# Enable/disable features for A/B testing
FEATURE_TWO_FACTOR_AUTH=true
FEATURE_SOCIAL_LOGIN=true
FEATURE_MARKETPLACE=true
FEATURE_LIVE_STREAMING=true
FEATURE_PAYMENTS=true
FEATURE_WALLET=true
FEATURE_FILE_UPLOAD=true
FEATURE_NOTIFICATIONS=true

# ───────────────────────────────────────────────────────────────────────────────
# 17. DEPLOYMENT CONFIGURATION
# ───────────────────────────────────────────────────────────────────────────────

DEPLOYMENT_ENV=production
DEPLOYMENT_REGION=us-east-1
DEPLOYMENT_REPLICAS=3
DEPLOYMENT_RESTART_POLICY=unless-stopped

# Docker configuration
DOCKER_IMAGE_TAG=latest
DOCKER_REGISTRY=your-registry.azurecr.io
DOCKER_USERNAME=your_docker_username
DOCKER_PASSWORD=your_docker_password

# ───────────────────────────────────────────────────────────────────────────────
# 18. Q POINTS MARKET SYSTEM
# ───────────────────────────────────────────────────────────────────────────────
# Licensed payment facilitator for P2P Q Point cash settlement.
# The platform never holds user funds — all cash movements are handled by the
# licensed facilitator. See docs/PAYMENT_FACILITATOR.md for integration guide.

# Facilitator API credentials (replace with live keys before going live)
PAYMENT_FACILITATOR_PROVIDER=paystack
PAYMENT_FACILITATOR_SECRET_KEY=sk_live_YOUR_PAYSTACK_OR_FLUTTERWAVE_SECRET_KEY_HERE
PAYMENT_FACILITATOR_PUBLIC_KEY=pk_live_YOUR_PAYSTACK_OR_FLUTTERWAVE_PUBLIC_KEY_HERE
# Webhook signature secret — verify all inbound webhook events with this
PAYMENT_FACILITATOR_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET_MIN_32_CHARS_HERE
# Publicly reachable URL for the payment webhook endpoint
PAYMENT_FACILITATOR_WEBHOOK_URL=https://api.yourapp.com/api/v1/qpoints/webhooks/payment
# Settlement currency (NGN for Paystack/Flutterwave; adjust for other providers)
PAYMENT_FACILITATOR_CURRENCY=NGN

# ── Flutterwave live credentials (set PROVIDER=flutterwave to use) ────────────
# PAYMENT_FACILITATOR_PROVIDER=flutterwave
# PAYMENT_FACILITATOR_SECRET_KEY=FLWSECK_LIVE-xxxxxxxxxxxxxxxxxxxxxx-X
# PAYMENT_FACILITATOR_PUBLIC_KEY=FLWPUBK_LIVE-xxxxxxxxxxxxxxxxxxxxxx-X
# FLUTTERWAVE_ENCRYPTION_KEY=xxxxxxxxxxxxxxxxxxxxxxxx   # for 3DS / card charges

# ── Paystack live credentials (set PROVIDER=paystack to use) ─────────────────
# PAYMENT_FACILITATOR_PROVIDER=paystack
# PAYMENT_FACILITATOR_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# PAYMENT_FACILITATOR_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── AI Market Maker ──────────────────────────────────────────────────────────
# Master toggle. Set true after smoke-testing with AI_MARKET_ENABLED=false first.
AI_MARKET_ENABLED=false

# UUID of the platform AI participant. Must exist in the users table.
# Created by seed: INSERT INTO users … WHERE id = '00000000-0000-0000-0000-000000000001'
AI_PARTICIPANT_USER_ID=00000000-0000-0000-0000-000000000001

# Q Point inventory management thresholds — proportional to 500 trillion hard cap
# Target: 50% | Min: 10% | Max: 98% of total supply
AI_TARGET_INVENTORY=250000000000000
AI_MIN_INVENTORY=50000000000000
AI_MAX_INVENTORY=490000000000000
QPOINTS_TOTAL_SUPPLY=500000000000000

# Desired bid-ask spread tightening target (percent of midpoint)
AI_TARGET_SPREAD_PCT=2.0

# Order sizes (in Q Points)
AI_ORDER_BASE_QTY=500
AI_MAX_ORDER_QTY=2500

# Safety limits
AI_MAX_OPEN_ORDERS=10
AI_ORDER_TTL_SECONDS=300
AI_RUN_INTERVAL_SECONDS=30
# Minimum platform USD cash reserve before AI is allowed to place buy orders
AI_MIN_CASH_RESERVE_USD=5000

# ───────────────────────────────────────────────────────────────────────────────
# 18. DATABASE BACKUP & MAINTENANCE
# ───────────────────────────────────────────────────────────────────────────────

# Backup Configuration
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_STORAGE=s3
BACKUP_S3_BUCKET=orionstack-backups
BACKUP_ENCRYPTION=true

# Maintenance Windows
MAINTENANCE_ENABLED=false
MAINTENANCE_WINDOW=02:00-03:00
MAINTENANCE_MESSAGE=System maintenance in progress

# ───────────────────────────────────────────────────────────────────────────────
# 19. PERFORMANCE OPTIMIZATION
# ───────────────────────────────────────────────────────────────────────────────

# Caching
CACHE_ENABLED=true
CACHE_TTL=3600
CACHE_MAX_SIZE=1000

# Compression
COMPRESSION_ENABLED=true
COMPRESSION_LEVEL=6

# Query Optimization
QUERY_TIMEOUT=30000
QUERY_CACHE=true

# ───────────────────────────────────────────────────────────────────────────────
# 20. COMPLIANCE & REGULATIONS
# ───────────────────────────────────────────────────────────────────────────────

# GDPR Compliance
GDPR_ENABLED=true
DATA_RETENTION_DAYS=1095
DELETE_INACTIVE_AFTER_DAYS=730

# Terms & Privacy
TERMS_VERSION=1.0.0
PRIVACY_VERSION=1.0.0
COOKIE_CONSENT_REQUIRED=true

# ═══════════════════════════════════════════════════════════════════════════════
# IMPORTANT DEPLOYMENT NOTES
# ═══════════════════════════════════════════════════════════════════════════════
#
# 1. CRITICAL VALUES TO UPDATE BEFORE PRODUCTION DEPLOYMENT:
#    - DB_PASSWORD
#    - JWT_SECRET
#    - JWT_REFRESH_SECRET
#    - REDIS_PASSWORD
#    - SESSION_SECRET
#    - PIN_ENCRYPTION_KEY
#    - SENDGRID_API_KEY
#    - TWILIO credentials
#    - AWS credentials
#    - All API keys and secrets
#
# 2. GENERATE STRONG SECRETS:
#    Linux/Mac: openssl rand -hex 32
#    Node.js: require('crypto').randomBytes(32).toString('hex')
#
# 3. VALIDATE CONFIGURATION:
#    npm run validate:env
#
# 4. SECURITY CHECKLIST:
#    □ All secrets are changed from defaults
#    □ HTTPS is enabled
#    □ Database backup is configured
#    □ Rate limiting is enabled
#    □ CORS origins are restricted
#    □ SSL certificates are valid
#    □ API keys are rotated
#    □ Monitoring is enabled
#
# 5. DEPLOYMENT STEPS:
#    1. Create this file from template
#    2. Update all values with production credentials
#    3. Save securely (use secret management service)
#    4. Run validation: npm run validate:env
#    5. Deploy: ./deploy.sh production
#    6. Monitor: tail -f logs/production.log
#
# 6. FOR DOCKER DEPLOYMENT:
#    - Source this file during docker build/run
#    - Use Docker secrets for sensitive values
#    - Do not commit to git
#    - Store in secure location only
#
# ═══════════════════════════════════════════════════════════════════════════════
